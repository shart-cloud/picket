{
  "name": "@picket/sigma-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @picket/core build && tsc -p tsconfig.json",
    "test": "pnpm --filter @picket/core build && pnpm --filter @picket/normalize build && vitest run",
    "typecheck": "pnpm --filter @picket/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@picket/core": "workspace:*",
    "re2js": "^2.8.3"
  },
  "devDependencies": {
    "@picket/normalize": "workspace:*"
  }
}
