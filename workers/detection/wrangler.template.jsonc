{
  "name": "picket-detection",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.01
    }
  },
  "queues": {
    "producers": [
      {
        "binding": "ALERT_QUEUE",
        "queue": "picket-alerts"
      }
    ]
  },
  "pipelines": [
    {
      "binding": "ALERTS_PIPELINE",
      "pipeline": "__STREAM_ALERTS__"
    }
  ],
  "d1_databases": [
    {
      "binding": "ALERT_STATE_DB",
      "database_name": "picket-alert-state",
      "database_id": "__ALERT_STATE_DB_ID__",
      "migrations_dir": "../alert-router/migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "STATEFUL_DETECTION",
        "class_name": "StatefulDetectionObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["StatefulDetectionObject"]
    }
  ]
}
