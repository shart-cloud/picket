{
  "name": "picket-admin",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "assets": {
    "directory": "../../apps/web/dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/health", "/device", "/device/*"]
  },
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.01
    }
  },
  "d1_databases": [
    {
      "binding": "AUTH_DB",
      "database_name": "picket-auth",
      "database_id": "__AUTH_DB_ID__"
    },
    {
      "binding": "ALERT_STATE_DB",
      "database_name": "picket-alert-state",
      "database_id": "__ALERT_STATE_DB_ID__",
      "migrations_dir": "../alert-router/migrations"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "QUERY_JOBS_QUEUE",
        "queue": "picket-query-jobs"
      }
    ]
  },
  "pipelines": [
    {
      "binding": "THREAT_INTEL_PIPELINE",
      "pipeline": "__STREAM_THREAT_INTEL__"
    },
    {
      "binding": "ASSETS_PIPELINE",
      "pipeline": "__STREAM_ASSETS__"
    },
    {
      "binding": "USERS_PIPELINE",
      "pipeline": "__STREAM_USERS__"
    }
  ],
  // Threat-intel IOC store for /api/v1/enrichment (M4). Same picket-config KV
  // namespace the ingest Worker reads (terraform output `kv_namespace_id`).
  "kv_namespaces": [
    {
      "binding": "ENRICHMENT_KV",
      "id": "__ENRICHMENT_KV_ID__"
    }
  ],
  "vars": {
    "CF_ACCESS_TEAM_DOMAIN": "__CF_ACCESS_TEAM_DOMAIN__",
    "CF_ACCESS_AUD": "__CF_ACCESS_AUD__",
    "PICKET_R2_WAREHOUSE": "__PICKET_R2_WAREHOUSE__",
    "PICKET_TABLE_SUFFIX": "__PICKET_TABLE_SUFFIX__"
    // Optional: "PICKET_NL_QUERY_MODEL" overrides the NL-query model (default claude-opus-4-8).
  }
  // Secrets (set via `wrangler secret put`):
  //   BETTER_AUTH_SECRET — signing secret for better-auth
  //   R2_SQL_TOKEN       — kept for backward compat; the runner Worker is the actual executor
  //   ANTHROPIC_API_KEY  — enables POST /api/v1/query/natural (NL→SQL); route 500s without it
  //
  // This Worker must be placed behind a Cloudflare Access application.
  // The middleware additionally verifies the Cf-Access-Jwt-Assertion JWT.
}
